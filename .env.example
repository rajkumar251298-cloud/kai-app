# Copy to .env.local and fill in real values. Never commit .env.local.
# Supabase: Project Settings → API → Project URL + anon (public) key.
# Add http://localhost:3000/auth/callback (and production URL) to Auth → URL Configuration → Redirect URLs.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: server-only — enables security_logs inserts from /api/chat (never expose to client).
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
